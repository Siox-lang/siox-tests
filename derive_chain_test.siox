module examples::derive_chain_test;
using std::logic::{ULogic};

// A user derivation chain of named enums, mirroring the logic hierarchy.
enum Base { A, B }
enum Extended : Base { C }

struct Header { valid: Bit, kind: uint[4] }
struct Packet : Header { data: uint[8] }

entity DUT {
    in u: ULogic;
    in v: Bit; in k: uint[4]; in dt: uint[8];
    out lg: Logic;         // ULogic -> Logic (widening/same-variant, auto)
    out hk: uint[4];       // Packet -> Header projection (auto)
    out ext: Extended;     // Base -> Extended (widening, auto)
}
impl DUT {
    lg = Logic(u);
    let pkt: Packet;
    pkt = Packet { .valid = v, .kind = k, .data = dt };
    let h: Header;
    h = Header(pkt);
    hk = h.kind;
    let b: Base = Base::A;
    ext = Extended(b);
}

#[test]
entity ChainTest {}
impl ChainTest {
    let u: ULogic = 'Z';
    let v: Bit = '1'; let k: uint[4] = 7; let dt: uint[8] = 42;
    let lg: Logic; let hk: uint[4]; let ext: Extended;
    let d: DUT = { .u = u, .v = v, .k = k, .dt = dt, .lg = lg, .hk = hk, .ext = ext };
    await 1ns;
    assert!(lg == 'Z', "ULogic -> Logic keeps 'Z'");
    assert!(hk == 7, "Packet -> Header projection");
    assert!(ext == Extended::A, "Base -> Extended widening keeps A");
}
