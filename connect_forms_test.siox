module examples::connect_forms_test;

using std::bits::uint;

// An entity port is connected in one of three struct-style forms: explicit
// (`.a = x`), name shorthand (`.a`), or positional (`x` by order). Ports may
// also be wired post-declaration through the instance (`dut.a = x`, `dut.y`).
entity Add {
    in a: uint[8];
    in b: uint[8];
    out y: uint[8];
}

impl Add {
    y = a + b;
}

// Form 3 (positional) + post-declaration wiring inside a structural entity:
// chain two adders, connecting each stage's ports by position and by
// instance-qualified assignment.
entity Chain {
    in x: uint[8];
    out z: uint[8];
}

impl Chain {
    let s1 = Add {};      // ports wired post-declaration
    let s2 = Add {};
    s1.a = x;
    s1.b = 1;
    s2.a = s1.y;          // s1 output feeds s2 input
    s2.b = 2;
    z = s2.y;
}

#[test]
entity ConnectFormsTest {}

impl ConnectFormsTest {
    let a: uint[8];
    let b: uint[8];
    let y: uint[8];

    // Form 1: explicit named connection.
    let named = Add { .a = a, .b = b, .y = y };

    a = 10;
    b = 20;
    assert!(y == 30, "explicit named");

    // Form 3 + post-declaration: drive Chain's input and read its output.
    let x: uint[8];
    let z: uint[8];
    let chain = Add { x, x, z };   // positional: a = x, b = x, y = z
    x = 7;
    assert!(z == 14, "positional a=b=x");

    // Post-declaration form: instantiate empty, then wire through the instance.
    let dut = Add {};
    dut.a = 3;
    dut.b = 4;
    assert!(dut.y == 7, "post-declaration dut.a / dut.y");
}
