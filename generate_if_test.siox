module examples::generate_if_test;

using std::bits::uint;

entity Inc {
    in a: uint[8];
    out y: uint[8];
}

impl Inc {
    y = a + 1;
}

// A generate-`if` selects structure at elaboration from a parameter: `EN != 0`
// inserts an `Inc` between the ports; otherwise the input passes through. The
// condition is compile-time constant, so only the taken branch is built.
entity Opt<EN: integer> {
    in a: uint[8];
    out y: uint[8];
}

impl Opt<EN: integer> {
    if EN > 0 {
        let s: Inc = { .a = a, .y = y };
    } else {
        y = a;
    }
}

// A generate-`for` with a nested generate-`if` builds a chain of `N` `Inc`
// stages out of 3 (the rest pass through) — instance-array elements created
// conditionally.
entity Chain<N: integer> {
    in a: uint[8];
    out y: uint[8];
}

impl Chain<N: integer> {
    let w: uint[8][4];
    let stage: Inc[3];
    w[0] = a;
    for i in 0..2 {
        if i < N {
            stage[i] = Inc { .a = w[i], .y = w[i+1] };
        } else {
            w[i+1] = w[i];
        }
    }
    y = w[3];
}

#[test]
entity GenerateIfTest {}

impl GenerateIfTest {
    let a: uint[8];
    let on: uint[8];
    let off: uint[8];

    let dut_on: Opt<EN = 1> = { .a = a, .y = on };
    let dut_off: Opt<EN = 0> = { .a = a, .y = off };

    a = 40;
    assert!(on == 41, "EN=1: Inc inserted");
    assert!(off == 40, "EN=0: passthrough");

    // Chain<N=2>: two +1 stages, then hold.
    let ci: uint[8];
    let co: uint[8];
    let chain: Chain<N = 2> = { .a = ci, .y = co };
    ci = 10;
    assert!(co == 12, "N=2: +1 +1 then passthrough");
}
