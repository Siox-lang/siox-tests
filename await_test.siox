module examples::await_test;
using std::logic::{Bit, Logic};
using std::bits::uint;

entity Counter<W: integer> {
    in clk: Bit;
    in rst: Logic;
    in en: Bit;
    out count: uint[W];
}
impl Counter<W: integer> {
    let value: uint[W] = 0;
    if clk.rising() {
        if rst == '1' { value = 0; } else if en { value = value + 1; }
    }
    count = value;
}

#[test]
entity AwaitEdge {}
impl AwaitEdge {
    let clk: Bit = '0';
    let rst: Logic = '1';
    let en: Bit = '1';
    let count: uint[8];
    let dut: Counter<W = 8> = { .clk = clk, .rst = rst, .en = en, .count = count };

    clk = not clk after 5ns; // background 10ns clock (VHDL-style)
    await clk.rising();       // first edge (still in reset)
    rst = '0';
    await count == 7;        // wait until the counter reaches 7
    assert!(count == 7, "reached 7 via await condition");
}
